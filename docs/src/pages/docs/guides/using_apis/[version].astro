---
import { Astro } from 'astro';
const { version } = Astro.params;
const swaggerPath = `/vjailbreak/swagger-ui/${version}/`;
---

---
title: Swagger UI for vJailbreak {version}
description: API Reference for vJailbreak {version}
---

<h1>Swagger UI for <code>{version}</code></h1>

<iframe
  src={swaggerPath}
  width="100%"
  height="700"
  style="border:1px solid #ccc; border-radius:8px; margin-bottom:2rem;"
  loading="lazy"
  title={`Swagger UI for vJailbreak ${version}`}
/>
